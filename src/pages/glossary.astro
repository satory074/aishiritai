---
import Layout from "@/components/Layout.astro";
import { allTerms } from "@/lib/glossary";

const terms = allTerms();
---

<Layout title="用語集" description="本文に登場するAIの専門用語を、技術の中身まで踏み込んで解説。パーセプトロンから拡散モデルまで。">
  <section class="wrap page">
    <p class="kicker">GLOSSARY</p>
    <h1 class="page__title mono">用語集</h1>
    <p class="page__lead">
      各時代の本文で点線つきの語にカーソルを合わせる（スマホはタップ）と、その場で同じ解説が出ます。
      ここでは全{terms.length}語を一覧できます。
    </p>
    <dl class="glo">
      {
        terms.map((t) => (
          <div class="glo__row" id={t.id}>
            <dt class="glo__term">
              <span class="glo__name">{t.term}</span>
              {t.reading && <span class="glo__reading mono">{t.reading}</span>}
            </dt>
            <dd class="glo__def">
              {t.def}
              {t.link && (
                <a class="glo__link mono" href={t.link} target="_blank" rel="noopener noreferrer">
                  → 出典
                </a>
              )}
            </dd>
          </div>
        ))
      }
    </dl>
  </section>
</Layout>

<style>
  .page {
    padding-block: 2.5rem;
  }
  .page__title {
    font-size: clamp(1.7rem, 5vw, 2.4rem);
    color: #fff;
    margin: 0.6rem 0 0;
  }
  .page__lead {
    margin: 0.8rem 0 2rem;
    color: var(--text-muted);
    max-width: 42rem;
  }
  .glo {
    margin: 0;
    border-top: 1px solid var(--border);
  }
  .glo__row {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border-soft);
    scroll-margin-top: 5rem;
  }
  @media (min-width: 720px) {
    .glo__row {
      display: grid;
      grid-template-columns: 230px 1fr;
      gap: 1.5rem;
    }
  }
  .glo__term {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .glo__name {
    font-weight: 700;
    color: hsl(var(--era-hue) 60% 82%);
  }
  .glo__reading {
    font-size: 0.74rem;
    color: var(--text-dim);
  }
  .glo__def {
    margin: 0.35rem 0 0;
    font-size: 0.92rem;
    line-height: 1.8;
    color: var(--text-muted);
  }
  @media (min-width: 720px) {
    .glo__def {
      margin-top: 0;
    }
  }
  .glo__link {
    display: inline-block;
    margin-left: 0.5rem;
    font-size: 0.74rem;
    color: hsl(var(--era-hue) 85% 70%);
    white-space: nowrap;
  }
</style>
