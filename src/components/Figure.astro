---
interface Props {
  caption?: string;
  label?: string;
}
const { caption, label = "FIG" } = Astro.props;
---

<figure class="fig not-prose">
  <div class="fig__frame">
    <slot />
  </div>
  {
    caption && (
      <figcaption class="fig__cap">
        <span class="fig__label mono">{label}</span>
        <span class="fig__text">{caption}</span>
      </figcaption>
    )
  }
</figure>

<style>
  .fig {
    margin: 1.8rem 0;
  }
  .fig__frame {
    padding: 1.3rem 1rem;
    background:
      radial-gradient(
        120% 120% at 50% 0%,
        hsl(var(--era-hue) 60% 50% / 0.06),
        transparent 60%
      ),
      var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow-x: auto;
  }
  /* 中の SVG / 図はフレーム内で中央寄せ・はみ出しは横スクロール */
  .fig__frame :global(svg) {
    display: block;
    margin-inline: auto;
    max-width: 100%;
    height: auto;
  }
  .fig__cap {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.7rem;
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--text-muted);
  }
  .fig__label {
    flex: none;
    color: hsl(var(--era-hue) 85% 66%);
    font-weight: 700;
    letter-spacing: 0.05em;
  }
</style>
