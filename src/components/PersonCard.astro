---
import { getPerson, initials } from "@/lib/people";
import { siteLink } from "@/lib/url";

interface Props {
  id: string;
}
const { id } = Astro.props;
const p = getPerson(id);

if (!p && import.meta.env.DEV) {
  console.warn(`[PersonCard] people に id="${id}" が見つかりません`);
}

const lifespan = p
  ? p.born
    ? `${p.born}–${p.died ?? ""}`
    : p.died
      ? `–${p.died}`
      : ""
  : "";

// public/ 配下の画像は base path を手で付ける（動的 src は Astro が自動解決しない）
const photoSrc = p?.photo ? siteLink(`/${p.photo.src}`) : null;
---

{
  p && (
    <aside class="pcard not-prose">
      <div class="pcard__head">
        {photoSrc ? (
          <img
            class="pcard__avatar pcard__avatar--photo"
            src={photoSrc}
            alt={`${p.name}（${p.en}）の顔写真`}
            width="60"
            height="60"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <span class="pcard__avatar pcard__avatar--initials mono" aria-hidden="true">
            {initials(p.en)}
          </span>
        )}
        <span class="pcard__id">
          <span class="pcard__name">{p.name}</span>
          <span class="pcard__en mono">
            {p.en}
            {lifespan && <span class="pcard__life"> · {lifespan}</span>}
          </span>
        </span>
      </div>
      <p class="pcard__role">{p.role}</p>
      {p.works.length > 0 && (
        <ul class="pcard__works">
          {p.works.map((w) => (
            <li>{w}</li>
          ))}
        </ul>
      )}
      {p.links && p.links.length > 0 && (
        <div class="pcard__links mono">
          {p.links.map((l) => (
            <a href={l.url} target="_blank" rel="noopener noreferrer">
              {l.label} ↗
            </a>
          ))}
        </div>
      )}
      {p.photo && (
        <p class="pcard__credit mono">
          <span aria-hidden="true">📷</span> {p.photo.by} ·{" "}
          <a href={p.photo.source} target="_blank" rel="noopener noreferrer">
            {p.photo.license} ↗
          </a>
        </p>
      )}
    </aside>
  )
}

<style>
  .pcard {
    margin: 1.6rem 0;
    padding: 1.1rem 1.2rem;
    background: linear-gradient(
      180deg,
      hsl(var(--era-hue) 50% 50% / 0.07),
      var(--surface)
    );
    border: 1px solid var(--border);
    border-left: 3px solid hsl(var(--era-hue) 85% 60%);
    border-radius: var(--radius);
  }
  .pcard__head {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .pcard__avatar {
    flex: none;
    width: 60px;
    height: 60px;
    border-radius: 50%;
  }
  .pcard__avatar--initials {
    display: grid;
    place-items: center;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--bg);
    background: hsl(var(--era-hue) 85% 66%);
    box-shadow: 0 0 14px hsl(var(--era-hue) 90% 60% / 0.45);
  }
  .pcard__avatar--photo {
    object-fit: cover;
    /* 顔は上寄りにあることが多いので中央やや上をクロップ中心にする */
    object-position: 50% 22%;
    background: var(--surface-2);
    border: 1px solid hsl(var(--era-hue) 70% 60% / 0.6);
    box-shadow:
      0 0 0 2px var(--surface),
      0 0 16px hsl(var(--era-hue) 90% 60% / 0.4);
  }
  .pcard__id {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .pcard__name {
    font-size: 1.02rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }
  .pcard__en {
    font-size: 0.74rem;
    color: var(--text-dim);
  }
  .pcard__life {
    color: var(--text-dim);
  }
  .pcard__role {
    margin: 0.75rem 0 0;
    font-size: 0.9rem;
    color: var(--text);
  }
  .pcard__works {
    margin: 0.6rem 0 0;
    padding-left: 1.1rem;
    font-size: 0.84rem;
    color: var(--text-muted);
  }
  .pcard__works li {
    margin-top: 0.2rem;
  }
  .pcard__works li::marker {
    color: hsl(var(--era-hue) 85% 62%);
  }
  .pcard__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
    margin-top: 0.7rem;
    font-size: 0.76rem;
  }
  .pcard__links a {
    color: hsl(var(--era-hue) 90% 74%);
    border: none;
  }
  .pcard__credit {
    margin: 0.85rem 0 0;
    padding-top: 0.6rem;
    border-top: 1px solid var(--border-soft);
    font-size: 0.66rem;
    line-height: 1.5;
    color: var(--text-dim);
  }
  .pcard__credit a {
    color: var(--text-muted);
    border: none;
  }
  .pcard__credit a:hover {
    color: hsl(var(--era-hue) 90% 74%);
  }
</style>
