---
import { getPerson, initials } from "@/lib/people";

interface Props {
  id: string;
}
const { id } = Astro.props;
const p = getPerson(id);

if (!p && import.meta.env.DEV) {
  console.warn(`[PersonCard] people に id="${id}" が見つかりません`);
}

const lifespan = p
  ? p.born
    ? `${p.born}–${p.died ?? ""}`
    : p.died
      ? `–${p.died}`
      : ""
  : "";
---

{
  p && (
    <aside class="pcard not-prose">
      <div class="pcard__head">
        <span class="pcard__avatar mono" aria-hidden="true">
          {initials(p.en)}
        </span>
        <span class="pcard__id">
          <span class="pcard__name">{p.name}</span>
          <span class="pcard__en mono">
            {p.en}
            {lifespan && <span class="pcard__life"> · {lifespan}</span>}
          </span>
        </span>
      </div>
      <p class="pcard__role">{p.role}</p>
      {p.works.length > 0 && (
        <ul class="pcard__works">
          {p.works.map((w) => (
            <li>{w}</li>
          ))}
        </ul>
      )}
      {p.links && p.links.length > 0 && (
        <div class="pcard__links mono">
          {p.links.map((l) => (
            <a href={l.url} target="_blank" rel="noopener noreferrer">
              {l.label} ↗
            </a>
          ))}
        </div>
      )}
    </aside>
  )
}

<style>
  .pcard {
    margin: 1.6rem 0;
    padding: 1.1rem 1.2rem;
    background: linear-gradient(
      180deg,
      hsl(var(--era-hue) 50% 50% / 0.07),
      var(--surface)
    );
    border: 1px solid var(--border);
    border-left: 3px solid hsl(var(--era-hue) 85% 60%);
    border-radius: var(--radius);
  }
  .pcard__head {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .pcard__avatar {
    flex: none;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--bg);
    background: hsl(var(--era-hue) 85% 66%);
    box-shadow: 0 0 14px hsl(var(--era-hue) 90% 60% / 0.45);
  }
  .pcard__id {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .pcard__name {
    font-size: 1.02rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }
  .pcard__en {
    font-size: 0.74rem;
    color: var(--text-dim);
  }
  .pcard__life {
    color: var(--text-dim);
  }
  .pcard__role {
    margin: 0.75rem 0 0;
    font-size: 0.9rem;
    color: var(--text);
  }
  .pcard__works {
    margin: 0.6rem 0 0;
    padding-left: 1.1rem;
    font-size: 0.84rem;
    color: var(--text-muted);
  }
  .pcard__works li {
    margin-top: 0.2rem;
  }
  .pcard__works li::marker {
    color: hsl(var(--era-hue) 85% 62%);
  }
  .pcard__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
    margin-top: 0.7rem;
    font-size: 0.76rem;
  }
  .pcard__links a {
    color: hsl(var(--era-hue) 90% 74%);
    border: none;
  }
</style>
