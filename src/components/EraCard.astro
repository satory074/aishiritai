---
import { siteLink } from "@/lib/url";

interface Props {
  id: string;
  order: number;
  title: string;
  period: string;
  summary: string;
  topics: string[];
  hue: number;
}
const { id, order, title, period, summary, topics, hue } = Astro.props;
const num = String(order).padStart(2, "0");
---

<a class="card" href={siteLink(`/eras/${id}`)} style={`--era-hue: ${hue}`}>
  <div class="card__top">
    <span class="card__num mono">{num}</span>
    <span class="card__period mono">{period}</span>
  </div>
  <h2 class="card__title">{title}</h2>
  <p class="card__summary">{summary}</p>
  {
    topics.length > 0 && (
      <ul class="card__topics mono">
        {topics.map((t) => (
          <li>{t}</li>
        ))}
      </ul>
    )
  }
  <span class="card__go mono">読む →</span>
</a>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.3rem 1.3rem 1.1rem;
    background: linear-gradient(
      180deg,
      hsl(var(--era-hue) 45% 45% / 0.08),
      var(--surface)
    );
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    overflow: hidden;
    transition:
      border-color 0.18s ease,
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }
  .card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      hsl(var(--era-hue) 90% 62%),
      transparent 75%
    );
    opacity: 0.7;
  }
  .card:hover {
    transform: translateY(-3px);
    border-color: hsl(var(--era-hue) 80% 55% / 0.6);
    box-shadow: 0 12px 34px hsl(var(--era-hue) 80% 30% / 0.28);
  }
  .card__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .card__num {
    font-size: 1.5rem;
    font-weight: 700;
    color: hsl(var(--era-hue) 85% 66%);
    text-shadow: 0 0 16px hsl(var(--era-hue) 90% 55% / 0.5);
  }
  .card__period {
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  .card__title {
    margin: 0.5rem 0 0;
    font-size: 1.12rem;
    line-height: 1.45;
    color: #fff;
  }
  .card__summary {
    margin: 0.55rem 0 0;
    font-size: 0.86rem;
    line-height: 1.7;
    color: var(--text-muted);
  }
  .card__topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0.9rem 0 0;
    padding: 0;
    list-style: none;
  }
  .card__topics li {
    font-size: 0.68rem;
    padding: 0.12rem 0.5rem;
    color: hsl(var(--era-hue) 40% 80%);
    border: 1px solid hsl(var(--era-hue) 60% 50% / 0.3);
    border-radius: 999px;
    background: hsl(var(--era-hue) 60% 50% / 0.06);
  }
  .card__go {
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.78rem;
    color: hsl(var(--era-hue) 85% 70%);
  }
</style>
