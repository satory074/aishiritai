---
// XOR と線形分離：AND/OR は1本の直線で分けられるが、XOR は分けられない
---

<svg viewBox="0 0 600 260" role="img" aria-label="AND・OR・XOR の線形分離可能性の比較">
  <!-- ===== AND ===== -->
  <g class="panel">
    <text class="title" x="90" y="22">AND</text>
    <rect class="frame" x="20" y="34" width="140" height="140" />
    <!-- separating line -->
    <line class="sep" x1="38" y1="166" x2="152" y2="48" />
    <!-- points: (0,0)=neg (1,0)=neg (0,1)=neg (1,1)=pos -->
    <circle class="pt pt--neg" cx="44" cy="160" r="9" />
    <circle class="pt pt--neg" cx="136" cy="160" r="9" />
    <circle class="pt pt--neg" cx="44" cy="48" r="9" />
    <circle class="pt pt--pos" cx="136" cy="48" r="9" />
    <text class="ok" x="90" y="196">線形分離 可</text>
  </g>

  <!-- ===== OR ===== -->
  <g class="panel">
    <text class="title" x="290" y="22">OR</text>
    <rect class="frame" x="220" y="34" width="140" height="140" />
    <line class="sep" x1="238" y1="100" x2="300" y2="180" />
    <!-- (0,0)=neg, others pos -->
    <circle class="pt pt--neg" cx="244" cy="160" r="9" />
    <circle class="pt pt--pos" cx="336" cy="160" r="9" />
    <circle class="pt pt--pos" cx="244" cy="48" r="9" />
    <circle class="pt pt--pos" cx="336" cy="48" r="9" />
    <text class="ok" x="290" y="196">線形分離 可</text>
  </g>

  <!-- ===== XOR ===== -->
  <g class="panel">
    <text class="title" x="490" y="22">XOR</text>
    <rect class="frame" x="420" y="34" width="140" height="140" />
    <!-- (0,0)=neg (1,1)=neg  /  (1,0)=pos (0,1)=pos -->
    <circle class="pt pt--neg" cx="444" cy="160" r="9" />
    <circle class="pt pt--pos" cx="536" cy="160" r="9" />
    <circle class="pt pt--pos" cx="444" cy="48" r="9" />
    <circle class="pt pt--neg" cx="536" cy="48" r="9" />
    <text class="ng" x="490" y="196">線形分離 不可</text>
  </g>

  <!-- legend -->
  <g class="legend">
    <circle class="pt pt--pos" cx="210" cy="236" r="8" />
    <text class="leg" x="226" y="236">出力 1</text>
    <circle class="pt pt--neg" cx="320" cy="236" r="8" />
    <text class="leg" x="336" y="236">出力 0</text>
  </g>
</svg>

<style>
  svg {
    width: 100%;
    max-width: 600px;
    font-family: var(--font-mono);
  }
  .frame {
    fill: var(--surface-2);
    stroke: var(--border);
    stroke-width: 1.5;
    rx: 6;
  }
  .sep {
    stroke: hsl(var(--era-hue) 85% 60%);
    stroke-width: 2.5;
    stroke-dasharray: 6 4;
  }
  .pt--pos {
    fill: hsl(var(--era-hue) 85% 60%);
    stroke: hsl(var(--era-hue) 85% 75%);
    stroke-width: 1.5;
  }
  .pt--neg {
    fill: var(--surface);
    stroke: var(--text-muted);
    stroke-width: 2;
  }
  .title {
    fill: var(--text);
    font-size: 16px;
    text-anchor: middle;
  }
  .ok {
    fill: hsl(var(--era-hue) 70% 65%);
    font-size: 13px;
    text-anchor: middle;
  }
  .ng {
    fill: hsl(8 80% 64%);
    font-size: 13px;
    text-anchor: middle;
    font-weight: 600;
  }
  .leg {
    fill: var(--text-muted);
    font-size: 12px;
    dominant-baseline: central;
  }
</style>
