---
import Demo from "@/components/Demo.astro";
// 自己注意のデモ。クエリ語をクリックすると、各語への注意の重み（softmax）が
// 文そのものの発光とバーで見える。温度 T を下げると注意が一点に尖る。
---

<Demo
  title="自己注意：どの語がどの語を見るか"
  caption="クエリ語をクリックすると、その語が文中の各語へ振り分ける注意の重み（合計1）が、文の発光とバーで分かる。代名詞「it」は中身（cat）を強く見る。温度 T を下げると注意は一点へ尖り、上げると平らになる——これが √dₖ スケーリングが調整している鋭さ。"
  label="DEMO 7.1"
>
  <div class="at" data-attn>
    <p class="at__hint d-note">クエリにする語をクリック →</p>
    <div class="at__sentence" data-tokens></div>

    <div class="d-row at__temp">
      <span class="d-label">温度 T</span>
      <input class="d-slider" data-temp type="range" min="0.3" max="3" step="0.1" value="1" />
      <span class="d-val" data-tempval>1.0</span>
      <span class="d-note" style="margin-left:.4rem">小さいほど鋭い softmax</span>
    </div>

    <div class="at__panel">
      <div class="at__formula mono">softmax(q·kⱼ / T)<span data-qword></span></div>
      <div class="at__bars" data-bars></div>
    </div>
  </div>
</Demo>

<script>
  const TOKENS = ["The", "cat", "ate", "the", "fish", "because", "it", "was", "full"];
  // 行=クエリ, 列=キー の親和度（logit）。意味的に手で設計。
  const LOGITS: number[][] = [
    [0.5, 2.5, 0.3, 0.0, 0.4, 0.0, 0.2, 0.0, 0.0], // The → cat
    [0.4, 1.5, 2.2, 0.0, 1.0, 0.0, 0.3, 0.0, 0.2], // cat → ate/fish
    [0.0, 2.4, 1.0, 0.0, 2.6, 0.0, 0.3, 0.0, 0.4], // ate → cat/fish
    [0.0, 0.3, 0.3, 0.5, 2.6, 0.0, 0.0, 0.0, 0.0], // the → fish
    [0.0, 1.2, 2.3, 0.3, 1.2, 0.0, 0.2, 0.0, 0.3], // fish → ate/cat
    [0.0, 0.4, 1.6, 0.0, 0.6, 0.6, 0.5, 1.4, 1.6], // because → clauses
    [0.2, 3.0, 0.6, 0.0, 1.1, 0.0, 0.8, 0.3, 0.5], // it → cat (coref!)
    [0.0, 0.3, 0.3, 0.0, 0.3, 0.2, 1.8, 0.6, 2.2], // was → it/full
    [0.0, 1.6, 0.3, 0.0, 0.6, 0.2, 2.0, 1.4, 0.8], // full → it/cat
  ];

  function softmax(xs: number[], T: number) {
    const m = Math.max(...xs);
    const ex = xs.map((x) => Math.exp((x - m) / T));
    const s = ex.reduce((a, b) => a + b, 0);
    return ex.map((e) => e / s);
  }

  function setup(root: HTMLElement) {
    const q = <T extends Element>(s: string) => root.querySelector(s) as T | null;
    const tokG = q<HTMLElement>("[data-tokens]")!;
    const barsG = q<HTMLElement>("[data-bars]")!;
    const qword = q<HTMLElement>("[data-qword]")!;
    let query = 6, // "it"
      T = 1;

    tokG.innerHTML = TOKENS.map(
      (t, i) => `<button class="at-tok" type="button" data-i="${i}">${t}</button>`
    ).join("");

    function render() {
      const w = softmax(LOGITS[query], T);
      // 文の各語を注意の重みで発光
      root.querySelectorAll<HTMLElement>(".at-tok").forEach((el, i) => {
        el.classList.toggle("at-tok--q", i === query);
        const a = w[i];
        el.style.setProperty("--a", a.toFixed(3));
      });
      qword.textContent = `　（query = “${TOKENS[query]}”）`;
      // バー
      const order = TOKENS.map((_, i) => i).sort((a, b) => w[b] - w[a]);
      barsG.innerHTML = order
        .map((i) => {
          const pct = (w[i] * 100).toFixed(0);
          return `<div class="at-bar"><span class="at-bar__lab mono">${TOKENS[i]}</span><span class="at-bar__track"><span class="at-bar__fill" style="width:${(w[i] * 100).toFixed(1)}%"></span></span><span class="at-bar__val mono">${pct}%</span></div>`;
        })
        .join("");
    }

    root.querySelectorAll<HTMLButtonElement>(".at-tok").forEach((btn) => {
      btn.addEventListener("click", () => {
        query = Number(btn.dataset.i);
        render();
      });
    });
    q<HTMLInputElement>("[data-temp]")!.addEventListener("input", (e) => {
      T = Number((e.target as HTMLInputElement).value);
      q<HTMLElement>("[data-tempval]")!.textContent = T.toFixed(1);
      render();
    });

    render();
  }

  document.querySelectorAll<HTMLElement>("[data-attn]").forEach(setup);
</script>

<style>
  .at {
    display: grid;
    gap: 0.9rem;
  }
  .at__hint {
    margin: 0;
  }
  .at__sentence {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  :global(.at-tok) {
    --a: 0;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text);
    background: hsl(var(--era-hue) 85% 55% / calc(var(--a) * 0.9));
    border: 1px solid hsl(var(--era-hue) 70% 55% / calc(0.25 + var(--a) * 0.75));
    border-radius: 6px;
    padding: 0.3rem 0.6rem;
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
    box-shadow: 0 0 calc(var(--a) * 16px) hsl(var(--era-hue) 90% 60% / calc(var(--a) * 0.8));
  }
  :global(.at-tok:hover) {
    border-color: hsl(var(--era-hue) 90% 70%);
  }
  :global(.at-tok--q) {
    color: #fff;
    border-color: #fff;
    outline: 2px solid hsl(var(--era-hue) 95% 72%);
    outline-offset: 1px;
  }
  .at__temp {
    margin-top: 0.2rem;
  }
  .at__panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.8rem 0.9rem;
    display: grid;
    gap: 0.6rem;
  }
  .at__formula {
    font-size: 0.82rem;
    color: hsl(var(--era-hue) 80% 76%);
  }
  .at__formula span {
    color: var(--text-dim);
  }
  .at__bars {
    display: grid;
    gap: 0.28rem;
  }
  :global(.at-bar) {
    display: grid;
    grid-template-columns: 4.5rem 1fr 2.6rem;
    align-items: center;
    gap: 0.5rem;
  }
  :global(.at-bar__lab) {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: right;
  }
  :global(.at-bar__track) {
    height: 9px;
    background: var(--surface-2);
    border-radius: 5px;
    overflow: hidden;
  }
  :global(.at-bar__fill) {
    display: block;
    height: 100%;
    background: hsl(var(--era-hue) 88% 62%);
    border-radius: 5px;
    transition: width 0.25s ease;
  }
  :global(.at-bar__val) {
    font-size: 0.76rem;
    color: var(--text-muted);
    text-align: right;
  }
</style>
